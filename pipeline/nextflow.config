params {
    input_path = 'ticket12137/01_RawData'
    ticket = params.input_path.split('/')[0]
    fastq_dir = "s3://ci-genome-tokyo/data/${params.input_path}"
    outdir = "s3://ci-genome-tokyo/data/${params.ticket}/results"
    
    genome_id = 'mm39'
    genomes {
        'mm39' {
            bwa_index = "s3://ci-genome-tokyo/references/mm39/bwa_index/GRCm39.fa"
            gsize = "mm"
        }
    }
}

// 安定動作のため Wave/Fusion は無効化
wave.enabled = false
fusion.enabled = false

profiles {
    awsbatch {
        process.executor = 'awsbatch'
        process.queue = 'bio-analysis-queue'
        process.container = '312466295096.dkr.ecr.ap-northeast-1.amazonaws.com/bio-analysis-tools:latest'
        
        aws.region = 'ap-northeast-1'
        aws.batch.jobRole = 'arn:aws:iam::312466295096:role/BioInfraStack-BatchJobRole37A83758-cBIhjhlZgmYr'
        workDir = "s3://ci-genome-tokyo/data/${params.ticket}/work"
    }
}

docker.enabled = true
