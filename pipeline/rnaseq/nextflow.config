params {
    // -------------------------------------------------------------------------
    // ラン固有パラメータ（-params-file で YAML から上書きする）
    // Usage: nextflow run main.nf -profile awsbatch -params-file params/ticket12137.yml
    // -------------------------------------------------------------------------
    input_path     = 'ticket12137/01_RawData'
    read_type      = 'PE'
    hisat2_species = 'human'
    hisat2_record  = 'hg38'
    rsem_species   = 'human'
    rsem_record    = 'hg38'

    // -------------------------------------------------------------------------
    // インフラ定数（通常変更不要）
    // -------------------------------------------------------------------------
    s3_bucket        = 's3://ci-genome-tokyo'
    ref_base         = "${params.s3_bucket}/ref"
    ecr_registry     = '312466295096.dkr.ecr.ap-northeast-1.amazonaws.com'
    container_qc     = 'bio-ngs-qc:latest'
    container_mapping = 'bio-ngs-mapping:latest'
    container_count  = 'bio-ngs-count:latest'
}

wave.enabled = false
fusion.enabled = false

process {
    executor = 'local'
    errorStrategy = 'retry'
    maxRetries = 3
    withLabel: 'qc'      { container = params.container_qc }
    withLabel: 'mapping'  { container = params.container_mapping }
    withLabel: 'count'    { container = params.container_count }
}

profiles {
    awsbatch {
        process.executor = 'awsbatch'
        process.queue = 'bio-analysis-queue'

        process {
            withLabel: 'qc'      { container = "${params.ecr_registry}/bio-ngs-qc:latest" }
            withLabel: 'mapping'  { container = "${params.ecr_registry}/bio-ngs-mapping:latest" }
            withLabel: 'count'    { container = "${params.ecr_registry}/bio-ngs-count:latest" }
        }

        aws.region = 'ap-northeast-1'
        aws.batch.jobRole = 'arn:aws:iam::312466295096:role/BioInfraStack-BatchJobRole37A83758-cBIhjhlZgmYr'
        workDir = "${params.s3_bucket}/work_rnaseq"
    }
}

docker.enabled = true
